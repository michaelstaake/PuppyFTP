{
  "name": "puppyftp",
  "version": "1.0.3",
  "description": "PuppyFTP — cute, fast, AI-powered FTP + SSH/SFTP + RDP desktop client (Windows)",
  "main": "out/main/index.js",
  "author": {
    "name": "Michael Staake",
    "email": "michael@staake.ai"
  },
  "license": "GPL-3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && node --input-type=module -e \"import {cpSync} from \\\"fs\\\"; try { cpSync(\\\"public\\\", \\\"out/renderer\\\", {recursive: true, force: true}); console.log(\\\"public assets copied\\\"); } catch(e){} \"",
    "preview": "electron-vite preview",
    "postinstall": "node scripts/rebuild-natives.mjs",
    "build:win": "electron-builder --win",
    "package": "npm run build && electron-builder",
    "rebuild:rdp": "node scripts/rebuild-natives.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.12.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^5.5.0",
    "basic-ftp": "^5.0.5",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^0.400.0",
    "openai": "^6.47.0",
    "puppyftp-rdp-host": "file:native/rdp-host",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ssh2": "^1.15.0",
    "ssh2-sftp-client": "^9.1.0",
    "undici": "^8.7.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.0",
    "electron-vite": "^3.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.puppyftp.app",
    "productName": "PuppyFTP",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        "portable"
      ],
      "icon": "build/icon.ico",
      "executableName": "PuppyFTP"
    },
    "nsis": {
      "shortcutName": "PuppyFTP",
      "uninstallDisplayName": "PuppyFTP",
      "artifactName": "PuppyFTP-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "PuppyFTP-Portable-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "michaelstaake",
      "repo": "PuppyFTP"
    },
    "asarUnpack": [
      "**/*.node",
      "**/puppyftp-rdp-host/**"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelstaake/PuppyFTP.git"
  },
  "bugs": {
    "url": "https://github.com/michaelstaake/PuppyFTP/issues"
  },
  "homepage": "https://github.com/michaelstaake/PuppyFTP",
  "engines": {
    "node": ">=20"
  }
}
